# ─── Banco de dados ───────────────────────────────────────────────────────────
# Local (Docker — veja docker-compose.yml):
DATABASE_URL="postgresql://redeflow:redeflow@localhost:5432/redeflow"

# Produção (Supabase — use o "Transaction Pooler", porta 6543):
# DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development       # "production" no Render

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere valores seguros com: openssl rand -base64 48
JWT_ACCESS_SECRET="dev-access-secret-troque-em-producao-32chars"
JWT_REFRESH_SECRET="dev-refresh-secret-troque-em-producao-32chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local:
CORS_ORIGIN="http://localhost:5173"
# Produção (múltiplas origens separadas por vírgula):
# CORS_ORIGIN="https://redeflow.vercel.app,https://meu-dominio.com"
