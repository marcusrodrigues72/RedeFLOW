# Banco de dados (copie docker-compose para os valores locais)
DATABASE_URL="postgresql://redeflow:redeflow@localhost:5432/redeflow"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — TROQUE EM PRODUÇÃO (mínimo 32 chars aleatórios)
JWT_ACCESS_SECRET="dev-access-secret-troque-em-producao-32chars"
JWT_REFRESH_SECRET="dev-refresh-secret-troque-em-producao-32chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# CORS — origem do frontend
CORS_ORIGIN="http://localhost:5173"
